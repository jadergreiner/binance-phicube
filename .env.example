# ─── Binance API ─────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Use "True" para operar na Testnet da Binance Futures
BINANCE_TESTNET=True

# ─── Símbolos e Timeframes ────────────────────────────────────────────────────
# Lista separada por vírgula
SYMBOLS=BTCUSDT,ETHUSDT
TIMEFRAMES=15m,1h

# ─── Gestão de Risco ──────────────────────────────────────────────────────────
# Percentual do capital total arriscado por operação (ex: 1.0 = 1%)
RISK_PER_TRADE_PCT=1.0

# Relação risco/retorno mínima (ex: 2.0 = take profit é 2x o stop loss)
RISK_REWARD_RATIO=2.0

# Alavancagem aplicada em cada símbolo
LEVERAGE=5

# Capital máximo alocado em operações simultâneas (% do saldo disponível)
MAX_CAPITAL_ALLOCATION_PCT=30.0

# Número máximo de operações abertas simultaneamente
MAX_OPEN_POSITIONS=3

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017
MONGODB_DATABASE=phicube

# ─── Aplicação ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Quantas candles históricas carregar no início para calcular indicadores
WARMUP_CANDLES=200

# ─── Dashboard — API Key READ_ONLY (sem permissão de trade) ───────────────────
# ATENÇÃO: use uma API Key separada, exclusivamente com permissão de leitura.
# Nunca reutilize as credenciais do bot aqui.
DASHBOARD_API_KEY=your_dashboard_readonly_api_key_here
DASHBOARD_API_SECRET=your_dashboard_readonly_api_secret_here

# ─── Telegram Notifications (opcional) ────────────────────────────────────────
# Para receber notificações de eventos críticos via Telegram
# Deixe vazio para desabilitar notificações
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Relatório periódico de performance (opcional) ────────────────────────────
# Intervalo em horas para envio automático do relatório de performance via Telegram
# 0 = desabilitado
PERFORMANCE_REPORT_INTERVAL_HOURS=24
