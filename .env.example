# ─── Binance API ─────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Use "True" para operar na Testnet da Binance Futures
BINANCE_TESTNET=True

# Modo simulação (paper trading) — ideal quando Testnet não está disponível
# True = simula execução de ordens localmente sem chamar a exchange
# Ainda usa dados reais de candles/preços (endpoints públicos)
SIMULATION_MODE=false
# Saldo inicial simulado em USDT para o modo paper trading
SIMULATION_INITIAL_BALANCE=10000.0

# ─── Símbolos e Timeframes ────────────────────────────────────────────────────
# Formato canônico (SPEC_018): SYMBOL:TIMEFRAME:LEVERAGE separado por vírgula
SYMBOL_TIMEFRAMES=BTCUSDT:15m:5,ETHUSDT:15m:5

# ─── Gestão de Risco ──────────────────────────────────────────────────────────
# Modo de position sizing: "fixed" (legado) ou "atr_with_guard" (SPEC_029)
# fixed: position size baseado em RISK_PER_TRADE_PCT do saldo
# atr_with_guard: position size baseado em RISK_PER_TRADE_USDT + ATR, com guard do fractal
SIZING_MODE=fixed

# Percentual do capital total arriscado por operação (ex: 1.0 = 1%)
# Usado apenas quando SIZING_MODE=fixed
RISK_PER_TRADE_PCT=1.0

# Risco fixo em USDT por operação (SPEC_029)
# Usado apenas quando SIZING_MODE=atr_with_guard
RISK_PER_TRADE_USDT=5.0

# Período do ATR para position sizing (SPEC_029)
ATR_PERIOD=14

# Multiplicador do ATR para effective_stop = max(fractal_sl, ATR * multiplier)
# Override por símbolo: ATR_MULTIPLIER_{SYMBOL} (ex: ATR_MULTIPLIER_XAUUSDT=3.0)
ATR_MULTIPLIER=2.0

# Position size mínimo e máximo em USDT (0 = sem limite)
MIN_POSITION_USDT=1.0
MAX_POSITION_USDT=0

# Relação risco/retorno mínima (ex: 2.0 = take profit é 2x o stop loss)
RISK_REWARD_RATIO=2.0

# Alavancagem aplicada em cada símbolo
LEVERAGE=5

# Capital máximo alocado em operações simultâneas (% do saldo disponível)
MAX_CAPITAL_ALLOCATION_PCT=30.0

# Número máximo de operações abertas simultaneamente
MAX_OPEN_POSITIONS=3

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Credenciais do MongoDB — obrigatórias em produção.
# Substitua 'adminuser' e 'strongpassword' por valores seguros e únicos.
MONGO_INITDB_ROOT_USERNAME=adminuser
MONGO_INITDB_ROOT_PASSWORD=strongpassword

# URI com autenticação — formato obrigatório para produção.
# Formato: mongodb://<usuario>:<senha>@<host>:<porta>/<banco>?authSource=admin
# NUNCA use URI sem credenciais (mongodb://mongo:27017) em produção.
MONGODB_URI=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@mongo:27017/phicube?authSource=admin
MONGODB_DATABASE=phicube

# ─── Aplicação ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Quantas candles históricas carregar no início para calcular indicadores
WARMUP_CANDLES=200
# Habilita sincronização dinâmica de monitores em runtime com sessões APPROVED no Mongo
RUNTIME_MONITOR_AUTO_SYNC=false
# Intervalo (s) entre reconciliações de runtime quando auto sync está habilitado
RUNTIME_MONITOR_AUTO_SYNC_INTERVAL_SECONDS=30

# ─── Dashboard — API Key READ_ONLY (sem permissão de trade) ───────────────────
# ATENÇÃO: use uma API Key separada, exclusivamente com permissão de leitura.
# Nunca reutilize as credenciais do bot aqui.
DASHBOARD_API_KEY=your_dashboard_readonly_api_key_here
DASHBOARD_API_SECRET=your_dashboard_readonly_api_secret_here
DASHBOARD_WRITE_AUTH_REQUIRED=false
DASHBOARD_WRITE_AUTH_TOKEN=

# ─── Telegram Notifications (opcional) ────────────────────────────────────────
# Para receber notificações de eventos críticos via Telegram
# Deixe vazio para desabilitar notificações
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Relatório periódico de performance (opcional) ────────────────────────────
# Intervalo em horas para envio automático do relatório de performance via Telegram
# 0 = desabilitado
PERFORMANCE_REPORT_INTERVAL_HOURS=24

# ─── Context7 MCP (opcional) ──────────────────────────────────────────────────
# API key recomendada para maior limite de uso de documentação
CONTEXT7_API_KEY=

# ─── Estratégia de Saída (SPEC_030) ─────────────────────────────────────────
# Modo de saída: "fixed" (TP único, comportamento legado) ou "partial" (TP parcial)
EXIT_STRATEGY=fixed

# Níveis de TP parcial (formato JSON, apenas para EXIT_STRATEGY=partial)
# Ex: [{"qty_pct": 50.0, "price_distance_pct": 2.0}, {"qty_pct": 50.0, "price_distance_pct": 4.0}]
TP_LEVELS=[{"qty_pct": 50.0, "price_distance_pct": 2.0}, {"qty_pct": 50.0, "price_distance_pct": 4.0}]

# Override de exit_strategy por símbolo (JSON, opcional)
# Ex: {"BTCUSDT": "partial", "ETHUSDT": "fixed"}
EXIT_STRATEGY_OVERRIDES={}

# ─── Trailing Stop (SPEC_030 V2) ─────────────────────────────────────
# Percentual de lucro para ativar o trailing stop (ex: 1.0 = 1% acima do entry)
TRAILING_ACTIVATION_PCT=1.0
# Callback rate do trailing stop (ex: 0.5 = 0.5% de distância do preço máximo)
TRAILING_CALLBACK_RATE=0.5
